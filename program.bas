10 REM *************************************
20 REM DARTMOUTH BASIC FUNCTIONALITY TEST
30 REM *************************************

40 PRINT "DARTMOUTH BASIC TEST"
50 PRINT

60 REM ----- ARITHMETIC -----

70 LET A = 2 + 3 * 4
80 LET B = (2 + 3) * 4
90 LET C = 2 ^ 5

100 PRINT "2+3*4 = ";A
110 PRINT "(2+3)*4 = ";B
120 PRINT "2^5 = ";C
130 PRINT

140 REM ----- COMPARISONS -----

150 IF A = 14 THEN 170
160 PRINT "ERROR: ="
170 IF B <> A THEN 190
180 PRINT "ERROR: <>"
190 IF A > 10 THEN 210
200 PRINT "ERROR: >"
210 IF A >= 14 THEN 230
220 PRINT "ERROR: >="
230 IF B < 25 THEN 250
240 PRINT "ERROR: <"
250 IF B <= 20 THEN 270
260 PRINT "ERROR: <="
270 PRINT "COMPARISON TESTS PASSED"
280 PRINT

290 REM ----- FOR/NEXT -----

